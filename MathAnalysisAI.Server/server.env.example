# ====================================================
# MathAnalysisAI 服务端环境配置模板
# 复制本文件为部署机上的真实 server.env 后再填入实际值。
# 本文件不是生产可直接使用的配置。
# server.env 不会被 Git 跟踪（根目录 .gitignore 已显式忽略）。
# 不要把真实 secrets 提交回仓库。
# ====================================================

# ---------------- 认证配置 ----------------
# 模式：LocalPassword（密码登录）/ DevelopmentUsername（仅用户名）/ Disabled / Oidc
Auth__Mode=Oidc
Auth__AllowRegistration=false
Auth__MinPasswordLength=6
Auth__BcryptWorkFactor=12

# LocalPassword / DevelopmentUsername 模式需要显式配置 JWT 签名密钥。
# 生产环境不要使用开发默认值。
Auth__TokenSigningKey=change_me_with_a_long_random_secret
Auth__TokenIssuer=MathAnalysisAI.Server
Auth__TokenAudience=MathAnalysisAI.Client
Auth__AccessTokenLifetimeMinutes=720

# OIDC 公共配置（生产默认）
Oidc__Authority=https://id.example.com/realms/math
Oidc__Audience=mathanalysis-api
Oidc__ClientId=mathanalysis-web
Oidc__Scopes=openid profile email
Oidc__RoleClaimType=role
Oidc__NameClaimType=preferred_username
Oidc__RequireHttpsMetadata=true
Oidc__RedirectPath=/login-callback.html
Oidc__PostLogoutRedirectPath=/login.html

# ---------------- 管理员账号 ----------------
# 首次启动时自动创建（若已存在则更新密码）。
# 管理员可切换视角、创建教师账号。
# 生产环境建议使用加密值：ENC:base64ciphertext
# 加密方法：dotnet run --project Tools/ConfigEncryptor -- "你的明文密码"
Admin__Username=admin
Admin__Password=change_me_please

# ---------------- 数据库连接 ----------------
# 覆盖 appsettings.json 中的连接串（生产部署必填）。
# Docker 部署示例：
# ConnectionStrings__DefaultConnection=Server=mathanalysis-sqlserver,1433;Database=MathAnalysisAI;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;MultipleActiveResultSets=true

# ---------------- LiteLLM / OCR ----------------
# 生产环境必须手动提供这些值。
# LiteLLM__ApiKey 缺失时，LLMGateway 与 OCR provider 都会在运行时报配置错误。
# LLMGateway__Mode=litellm
# LiteLLM__ApiKey=sk-...
# LiteLLM__BaseUrl=http://mathanalysis-litellm:4000/v1/chat/completions
# PhotoSolutionOcr__Provider=litellm

# ---------------- 反向代理 / 运行绑定 ----------------
# Docker Compose 通常通过 ASPNETCORE_URLS 控制运行时绑定。
# 示例：
# ASPNETCORE_URLS=http://+:8080
# ForwardedHeaders__KnownNetworks=172.16.0.0/12
