{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=MathAnalysisAI;Trusted_Connection=True;MultipleActiveResultSets=true"
  },

  "DeepSeek": {
    "BaseUrl": "https://api.deepseek.com/v1/chat/completions"
  },
  "LLMGateway": {
    "Mode": "direct",
    "TimeoutSeconds": 60,
    "MaxRetryAttempts": 2,
    "RetryDelayMilliseconds": 800,
    "RetryOnStatusCodes": [429, 502, 503, 504],
    "MaxErrorBodyLength": 2000,
    "RequestTypeModelMap": {
      "review_solution": "math-reviewer",
      "solve": "math-solver",
      "hint": "math-hint",
      "concept_explain": "math-explainer",
      "exam_mode": "math-reviewer"
    }
  },
  "LiteLLM": {
    "BaseUrl": "http://localhost:4000/v1/chat/completions"
  },
  "PhotoSolutionOcr": {
    "Provider": "litellm",
    "ModelAlias": "photo-solution-ocr",
    "MaxImageBytes": 10485760,
    "TimeoutSeconds": 90,
    "MaxRetryAttempts": 2,
    "RetryDelayMilliseconds": 800,
    "RetryOnStatusCodes": [429, 502, 503, 504],
    "MaxErrorBodyLength": 2000
  },
  "Symbolic": {
    "Enabled": true,
    "Provider": "sympy",
    "PythonExecutable": "python3",
    "WorkerPath": "Tools/Symbolic/symbolic_worker.py",
    "TimeoutMs": 3000,
    "MaxExpressionLength": 1000
  },
  "AnalysisContext": {
    "EnableKnowledgeRetrieval": false,
    "KnowledgeTopK": 3,
    "MaxKnowledgeContextChars": 1200,
    "MaxChunkPreviewChars": 400,
    "EnableSymbolicEvidence": false,
    "MaxSymbolicTasks": 2,
    "MaxSymbolicContextChars": 1000
  },
  "Auth": {
    "Mode": "Disabled",
    "EnableDevelopmentFallback": false,
    "DevelopmentFallbackUser": "test_student",
    "EnableDevelopmentMaterialAccessOverride": false,
    "EnableDevelopmentSymbolicAccessOverride": false,
    "RequireHttps": true,
    "CookieSecurePolicy": "Always",
    "CookieSameSite": "Lax",
    "CookieName": ".MathAnalysisAI.Auth",
    "BcryptWorkFactor": 12,
    "AllowRegistration": false,
    "MinPasswordLength": 6
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "AllowedHosts": "*"
}
